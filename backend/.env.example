# ===== App =====
APP_NAME=spider_jp_worldlink
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8009
APP_DEBUG=true

# ===== Security =====
# 用于 JWT 签名，请改成强随机串
SECRET_KEY=please-change-me-to-a-strong-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 用于加密存储大模型 API Key 等敏感字段（必须是 32 字节 base64 urlsafe）
# 生成方法：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=spider_jp_worldlink
MYSQL_CHARSET=utf8mb4

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== Apify =====
APIFY_TOKEN=
# 五种抓取场景对应的 actor，覆盖默认值时改这里
APIFY_FB_SEARCH_ACTOR=apify/facebook-search-scraper            # 关键词→Pages
APIFY_FB_PAGES_ACTOR=apify/facebook-pages-scraper              # PageURL→主页详情
APIFY_FB_POSTS_ACTOR=apify/facebook-posts-scraper              # PageURL→帖子（备用）
APIFY_FB_PROFILE_POSTS_ACTOR=cleansyntax/facebook-profile-posts-scraper  # 主页 URL/关键词→帖子
APIFY_FB_HASHTAG_ACTOR=apify/facebook-hashtag-scraper          # hashtag→帖子
APIFY_FB_SEARCH_POSTS_ACTOR=scrapeforge/facebook-search-posts  # 任意关键词→帖子(第三方)
APIFY_IG_PROFILE_ACTOR=apify/instagram-profile-scraper         # IG 用户名→主页资料
# 个人/创作者主页兜底：pages-scraper 抓 Profile 类账号数据稀疏时改用此 actor 再抓一次
# Apify 无官方 facebook-profile-scraper，默认用社区 actor（按 profileUrls 输入），可换别的
APIFY_FB_PROFILE_ACTOR=apivault_labs/facebook-profile-scraper   # 个人/创作者主页兜底
APIFY_FB_PROFILE_FALLBACK=true                                  # 关掉兜底设为 false

# ===== BitBrowser 比特浏览器（本地 Local API）=====
# 文档：https://doc.bitbrowser.net/zh/api-jie-kou-wen-dang/liu-lan-qi-jie-kou
# 每个登录用户在系统内「浏览器窗口」页自行配置本机地址与 API Token（存 users 表），勿写进共享 .env
# 客户端开启「Local API 鉴权」时的 API Token（设置 → Local API）；用户没在页面单独配置时用这里的值
BITBROWSER_API_KEY=
BITBROWSER_HTTP_TIMEOUT_SEC=60
BITBROWSER_LIST_PAGE_SIZE=100

# ===== Default Admin (首次启动会自动创建) =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
