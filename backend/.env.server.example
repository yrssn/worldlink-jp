# ============================================================
# 服务器部署参考（复制为 backend/.env 后逐项修改）
# 与本地 backend/.env 字段一致；勿把含密钥的文件提交到 Git
# ============================================================

# ----- 场景说明 -----
# A) 用仓库根目录 docker-compose.yml：MySQL 在外部 mysql-net，Redis 在 compose 里
#    → MYSQL_HOST=你的 MySQL「容器名」，MYSQL_PORT=3306
#    → REDIS_HOST=redis（服务名），与 compose 内 redis 一致
# B) Redis 单独起（见 docker/redis/docker-compose.yml），应用 compose 去掉内置 redis 后
#    → REDIS_HOST=redis（与独立 compose 里 service 名一致），两栈需在同一 Docker 网络
# C) 后端不用 Docker、直接宿主机跑 run.py
#    → MYSQL_HOST=127.0.0.1 或内网 IP，MYSQL_PORT=宿主机映射端口（如 3666）
#    → REDIS_HOST=127.0.0.1，REDIS_PORT=6379

# ===== App =====
APP_NAME=spider_jp_worldlink
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8009
APP_DEBUG=false

# ===== Security =====
SECRET_KEY=请改成至少 32 位随机字符串
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 大模型 API Key 等对称加密用（须为 Fernet 密钥）
# 生成：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ===== MySQL（与你在服务器 MySQL 里配置的一致）=====
# Docker 连「MySQL 容器」：MYSQL_HOST=容器名（你当前为 shared-mysql），MYSQL_PORT=3306
# 密码若含 # 等特殊字符，必须整段用英文双引号包起来，例如：
#   MYSQL_PASSWORD="Aut0Pub!ic_2024#Mx"
MYSQL_HOST=shared-mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD="CHANGE_ME_TO_REAL_PASSWORD"
MYSQL_DB=spider_jp_worldlink
MYSQL_CHARSET=utf8mb4

# ===== Redis =====
# 与仓库根目录 docker-compose.yml 内置 redis 一致（默认密码 123456）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=123456

# ===== Apify =====
APIFY_TOKEN=
APIFY_FB_SEARCH_ACTOR=apify/facebook-search-scraper
APIFY_FB_PAGES_ACTOR=apify/facebook-pages-scraper
APIFY_FB_POSTS_ACTOR=apify/facebook-posts-scraper
APIFY_FB_HASHTAG_ACTOR=apify/facebook-hashtag-scraper
APIFY_FB_SEARCH_POSTS_ACTOR=scrapeforge/facebook-search-posts

# ===== Uvicorn（仅 Docker 入口使用）=====
UVICORN_WORKERS=2

# ===== Default Admin（首次 init 会创建）=====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=请改成强密码
