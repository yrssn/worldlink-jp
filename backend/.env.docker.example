# ============================================================
# Docker 部署用 .env 示例（容器内网络）
# 复制并改名为 backend/.env 再启动 compose
# ============================================================

# ===== App =====
APP_NAME=spider_jp_worldlink
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8009
APP_DEBUG=false

# ===== Security =====
SECRET_KEY=please-change-me-to-a-strong-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 32 字节 urlsafe base64
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ===== MySQL（外部容器，通过 mysql-net 网络连接）=====
# 这里写的是【MySQL 容器名 + 容器内端口】，不是宿主机 IP/端口
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DB=spider_jp_worldlink
MYSQL_CHARSET=utf8mb4

# ===== Redis（compose 内置 redis 服务）=====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=123456

# ===== Apify =====
APIFY_TOKEN=
APIFY_FB_SEARCH_ACTOR=apify/facebook-search-scraper
APIFY_FB_PAGES_ACTOR=apify/facebook-pages-scraper
APIFY_FB_POSTS_ACTOR=apify/facebook-posts-scraper
APIFY_FB_HASHTAG_ACTOR=apify/facebook-hashtag-scraper
APIFY_FB_SEARCH_POSTS_ACTOR=scrapeforge/facebook-search-posts
APIFY_IG_PROFILE_ACTOR=apify/instagram-profile-scraper

# ===== Uvicorn =====
UVICORN_WORKERS=2

# ===== Default Admin =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
